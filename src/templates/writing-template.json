{
  "id": "writing",
  "name": "Writing and Content Creation",
  "description": "Structured workflow for writing, editing, and polishing content with quality review",
  "workflowType": "writing",
  "category": "content",
  "version": "1.0",
  "tags": ["writing", "content", "editing"],
  "defaultMode": "auto",
  "estimatedDuration": "20min-2h",
  "typicalSteps": 6,
  "metadata": {
    "requiresScan": false,
    "requiresApproval": false,
    "requiresCodegraph": false,
    "outputTypes": ["document", "file", "summary"]
  },
  "steps": [
    {
      "id": "understand-writing-requirements",
      "title": "Understand writing requirements",
      "description": "Analyze writing scope, target audience, tone, style, and format requirements",
      "taskType": "writing",
      "actionType": "analyze",
      "executor": "shell",
      "targetArtifacts": ["writing-requirements"],
      "expectedResult": "Writing requirements and style defined",
      "expectedOutputType": "analysis",
      "acceptanceCriteria": ["Writing scope, audience, and tone are defined"],
      "evidence": ["requirements file exists"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Defines what to write and how"
    },
    {
      "id": "create-outline",
      "title": "Create content outline",
      "description": "Create a structured outline with sections, key points, and flow",
      "taskType": "writing",
      "actionType": "create",
      "executor": "shell",
      "dependsOn": ["understand-writing-requirements"],
      "inputContext": "Writing requirements",
      "targetArtifacts": ["content-outline"],
      "expectedResult": "Content outline with structured sections",
      "expectedOutputType": "document",
      "acceptanceCriteria": ["Outline exists with structured sections"],
      "evidence": ["outline file exists"],
      "validationMethod": "file_exists",
      "riskLevel": "safe",
      "finalOutputContribution": "Blueprint for writing"
    },
    {
      "id": "write-first-draft",
      "title": "Write first draft",
      "description": "Write the initial draft following the outline and style guidelines",
      "taskType": "writing",
      "actionType": "create",
      "executor": "shell",
      "dependsOn": ["create-outline"],
      "inputContext": "Outline, style requirements",
      "targetFiles": ["docs/"],
      "targetArtifacts": ["first-draft"],
      "expectedResult": "First draft with complete content",
      "expectedOutputType": "document",
      "acceptanceCriteria": ["First draft covers all outline sections"],
      "evidence": ["draft file exists"],
      "validationMethod": "file_exists",
      "riskLevel": "safe",
      "retryPolicy": { "maxRetries": 2, "retryDelayMs": 1000 },
      "timeout": 300000,
      "finalOutputContribution": "Initial content deliverable"
    },
    {
      "id": "review-and-edit",
      "title": "Review and edit content",
      "description": "Review for tone, clarity, grammar, structure, and consistency. Apply edits",
      "taskType": "review",
      "actionType": "review",
      "executor": "shell",
      "dependsOn": ["write-first-draft"],
      "inputContext": "First draft, writing requirements",
      "targetFiles": ["docs/"],
      "targetArtifacts": ["review-notes"],
      "expectedResult": "Content reviewed and edited for quality",
      "expectedOutputType": "document",
      "acceptanceCriteria": ["Content is reviewed and edited for tone, clarity, and grammar"],
      "evidence": ["edits applied"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Quality improvement pass"
    },
    {
      "id": "polish-and-finalize",
      "title": "Polish and finalize content",
      "description": "Apply final polishing, verify formatting, and produce the final version",
      "taskType": "writing",
      "actionType": "modify",
      "executor": "shell",
      "dependsOn": ["review-and-edit"],
      "inputContext": "Edited content, requirements",
      "targetFiles": ["docs/"],
      "targetArtifacts": ["final-content"],
      "expectedResult": "Final polished content ready for delivery",
      "expectedOutputType": "document",
      "acceptanceCriteria": ["Final content is polished and complete"],
      "evidence": ["final content exists"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Final writing deliverable"
    },
    {
      "id": "validate-output",
      "title": "Validate output quality",
      "description": "Verify content meets all requirements and quality standards",
      "taskType": "validation",
      "actionType": "validate",
      "executor": "shell",
      "dependsOn": ["polish-and-finalize"],
      "inputContext": "Final content, requirements",
      "targetArtifacts": ["validation-results"],
      "expectedResult": "Content validated against all requirements",
      "expectedOutputType": "report",
      "acceptanceCriteria": ["Content meets all requirements and quality standards"],
      "evidence": ["validation completed"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Confirms content quality"
    }
  ]
}
