{
  "id": "operations",
  "name": "Operations Workflow",
  "description": "Structured workflow for system operations, maintenance, monitoring, and infrastructure tasks",
  "workflowType": "operations",
  "category": "operations",
  "version": "1.0",
  "tags": ["operations", "infrastructure", "maintenance", "devops"],
  "defaultMode": "manual",
  "estimatedDuration": "15min-2h",
  "typicalSteps": 6,
  "metadata": {
    "requiresScan": true,
    "requiresApproval": true,
    "requiresCodegraph": false,
    "outputTypes": ["command_result", "log_output", "report", "config_change"]
  },
  "steps": [
    {
      "id": "understand-operations-task",
      "title": "Understand operations task",
      "description": "Define the operations task scope, target systems, expected outcomes, and success criteria",
      "taskType": "operations",
      "actionType": "analyze",
      "executor": "shell",
      "targetArtifacts": ["ops-task-definition"],
      "expectedResult": "Operations task defined with scope and criteria",
      "expectedOutputType": "analysis",
      "acceptanceCriteria": ["Operations scope and success criteria are defined"],
      "evidence": ["task definition exists"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Defines ops objectives"
    },
    {
      "id": "assess-current-state",
      "title": "Assess current state",
      "description": "Review current system state, configuration, logs, and monitoring data",
      "taskType": "operations",
      "actionType": "read",
      "executor": "shell",
      "dependsOn": ["understand-operations-task"],
      "inputContext": "Operations task definition",
      "targetArtifacts": ["current-state-assessment"],
      "expectedResult": "Current system state assessed",
      "expectedOutputType": "analysis",
      "acceptanceCriteria": ["Current state is documented with relevant details"],
      "evidence": ["assessment exists"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Baseline for operations"
    },
    {
      "id": "plan-operations",
      "title": "Plan operations procedure",
      "description": "Design the operations procedure, commands to run, order of operations, and rollback steps",
      "taskType": "operations",
      "actionType": "analyze",
      "executor": "shell",
      "dependsOn": ["assess-current-state"],
      "inputContext": "Current state, ops task",
      "targetArtifacts": ["ops-plan"],
      "expectedResult": "Operations procedure planned",
      "expectedOutputType": "report",
      "acceptanceCriteria": ["Operations plan has clear steps and rollback"],
      "evidence": ["plan exists"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Procedure blueprint"
    },
    {
      "id": "execute-operations",
      "title": "Execute operations procedure",
      "description": "Execute the planned operations commands and procedures in order",
      "taskType": "operations",
      "actionType": "execute",
      "executor": "shell",
      "dependsOn": ["plan-operations"],
      "inputContext": "Operations plan",
      "targetArtifacts": ["execution-logs"],
      "expectedResult": "Operations executed successfully",
      "expectedOutputType": "command_result",
      "acceptanceCriteria": ["Operations commands execute successfully"],
      "evidence": ["exit code 0"],
      "verificationCommand": "",
      "validationMethod": "command_output",
      "approvalRequired": true,
      "riskLevel": "dangerous",
      "retryPolicy": { "maxRetries": 1, "retryDelayMs": 5000 },
      "timeout": 300000,
      "finalOutputContribution": "Core ops execution"
    },
    {
      "id": "verify-operations",
      "title": "Verify operations outcome",
      "description": "Verify the operations completed successfully and the system is in the expected state",
      "taskType": "validation",
      "actionType": "validate",
      "executor": "shell",
      "dependsOn": ["execute-operations"],
      "inputContext": "Execution logs, ops plan",
      "targetArtifacts": ["verification-results"],
      "expectedResult": "Operations verified as successful",
      "expectedOutputType": "log_output",
      "acceptanceCriteria": ["System state matches expected outcome"],
      "evidence": ["verification commands pass"],
      "verificationCommand": "",
      "validationMethod": "command_output",
      "riskLevel": "safe",
      "timeout": 120000,
      "finalOutputContribution": "Confirms ops success"
    },
    {
      "id": "generate-report",
      "title": "Generate operations report",
      "description": "Document operations performed, results, any issues encountered, and recommendations",
      "taskType": "documentation",
      "actionType": "generate",
      "executor": "shell",
      "dependsOn": ["verify-operations"],
      "inputContext": "All ops outputs",
      "targetFiles": ["reports/ops-report.md"],
      "targetArtifacts": ["ops-report"],
      "expectedResult": "Operations report with summary",
      "expectedOutputType": "report",
      "acceptanceCriteria": ["Operations report exists with details"],
      "evidence": ["report file exists"],
      "validationMethod": "file_exists",
      "riskLevel": "safe",
      "finalOutputContribution": "Final ops deliverable"
    }
  ]
}
