{
  "id": "product-planning",
  "name": "Product Planning",
  "description": "Structured workflow for product planning including feature definition, prioritization, roadmap creation, and release planning",
  "workflowType": "product-planning",
  "category": "planning",
  "version": "1.0",
  "tags": ["product", "planning", "roadmap", "strategy"],
  "defaultMode": "auto",
  "estimatedDuration": "1h-4h",
  "typicalSteps": 7,
  "metadata": {
    "requiresScan": false,
    "requiresApproval": true,
    "requiresCodegraph": false,
    "outputTypes": ["report", "checklist", "analysis", "recommendation"]
  },
  "steps": [
    {
      "id": "understand-product-vision",
      "title": "Understand product vision and goals",
      "description": "Review product vision, strategic goals, and success metrics",
      "taskType": "analysis",
      "actionType": "read",
      "executor": "shell",
      "targetArtifacts": ["product-vision-summary"],
      "expectedResult": "Product vision and goals documented",
      "expectedOutputType": "analysis",
      "acceptanceCriteria": ["Product vision and goals are documented"],
      "evidence": ["vision summary exists"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Foundation for planning decisions"
    },
    {
      "id": "define-features",
      "title": "Define features and requirements",
      "description": "Define features, user stories, and requirements for the planning scope",
      "taskType": "analysis",
      "actionType": "analyze",
      "executor": "shell",
      "dependsOn": ["understand-product-vision"],
      "inputContext": "Product vision, user prompt",
      "targetArtifacts": ["feature-definitions"],
      "expectedResult": "Features and requirements defined",
      "expectedOutputType": "analysis",
      "acceptanceCriteria": ["Features and requirements are defined"],
      "evidence": ["feature document exists"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "What needs to be built"
    },
    {
      "id": "prioritize-backlog",
      "title": "Prioritize and estimate effort",
      "description": "Prioritize features by value, effort, risk and create a prioritized backlog",
      "taskType": "analysis",
      "actionType": "analyze",
      "executor": "shell",
      "dependsOn": ["define-features"],
      "inputContext": "Feature definitions",
      "targetArtifacts": ["prioritized-backlog"],
      "expectedResult": "Prioritized backlog with effort estimates",
      "expectedOutputType": "analysis",
      "acceptanceCriteria": ["Features are prioritized with estimates"],
      "evidence": ["backlog exists"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Ordered work items for planning"
    },
    {
      "id": "create-roadmap",
      "title": "Create product roadmap",
      "description": "Create a timeline-based roadmap with phases, milestones, and delivery targets",
      "taskType": "general",
      "actionType": "generate",
      "executor": "shell",
      "dependsOn": ["prioritize-backlog"],
      "inputContext": "Prioritized backlog, estimates",
      "targetArtifacts": ["product-roadmap"],
      "expectedResult": "Product roadmap with phases and milestones",
      "expectedOutputType": "report",
      "acceptanceCriteria": ["Roadmap has timeline, phases, and milestones"],
      "evidence": ["roadmap exists"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Timeline for delivery"
    },
    {
      "id": "identify-risks",
      "title": "Identify risks and dependencies",
      "description": "Identify technical risks, resourcing risks, external dependencies, and mitigation strategies",
      "taskType": "analysis",
      "actionType": "analyze",
      "executor": "shell",
      "dependsOn": ["create-roadmap"],
      "inputContext": "Roadmap, features, estimates",
      "targetArtifacts": ["risk-assessment"],
      "expectedResult": "Risks and dependencies documented with mitigations",
      "expectedOutputType": "analysis",
      "acceptanceCriteria": ["Risks and dependencies are identified"],
      "evidence": ["risk assessment exists"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Risk awareness for execution"
    },
    {
      "id": "define-release-plan",
      "title": "Define release plan",
      "description": "Define release criteria, version planning, and go-to-market approach",
      "taskType": "general",
      "actionType": "generate",
      "executor": "shell",
      "dependsOn": ["identify-risks"],
      "inputContext": "Roadmap, risks, features",
      "targetArtifacts": ["release-plan"],
      "expectedResult": "Release plan with criteria and timeline",
      "expectedOutputType": "checklist",
      "acceptanceCriteria": ["Release plan exists with criteria"],
      "evidence": ["release plan exists"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Plan for delivery execution"
    },
    {
      "id": "generate-report",
      "title": "Generate product plan report",
      "description": "Produce comprehensive product plan with roadmap, priorities, risks, and release approach",
      "taskType": "documentation",
      "actionType": "generate",
      "executor": "shell",
      "dependsOn": ["define-release-plan"],
      "inputContext": "All planning outputs",
      "targetFiles": ["reports/product-plan.md"],
      "targetArtifacts": ["product-plan"],
      "expectedResult": "Product plan report with all sections",
      "expectedOutputType": "report",
      "acceptanceCriteria": ["Product plan report exists"],
      "evidence": ["report file exists"],
      "validationMethod": "file_exists",
      "riskLevel": "safe",
      "finalOutputContribution": "Final product planning deliverable"
    }
  ]
}
