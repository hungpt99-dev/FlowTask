{
  "id": "meeting-summary",
  "name": "Meeting Summary",
  "description": "Structured workflow for processing meeting notes or transcripts into organized summaries with action items",
  "workflowType": "meeting-summary",
  "category": "content",
  "version": "1.0",
  "tags": ["meeting", "summary", "notes", "action-items"],
  "defaultMode": "auto",
  "estimatedDuration": "10-30min",
  "typicalSteps": 5,
  "metadata": {
    "requiresScan": false,
    "requiresApproval": false,
    "requiresCodegraph": false,
    "outputTypes": ["summary", "report", "checklist"]
  },
  "steps": [
    {
      "id": "collect-meeting-input",
      "title": "Collect meeting input",
      "description": "Gather meeting notes, transcript, agenda, or any available input material",
      "taskType": "general",
      "actionType": "read",
      "executor": "shell",
      "targetArtifacts": ["meeting-input"],
      "expectedResult": "Meeting input material collected",
      "expectedOutputType": "file",
      "acceptanceCriteria": ["Meeting input material is available"],
      "evidence": ["input collected"],
      "validationMethod": "file_exists",
      "riskLevel": "safe",
      "finalOutputContribution": "Raw meeting material"
    },
    {
      "id": "extract-key-points",
      "title": "Extract key points and decisions",
      "description": "Analyze the meeting material to extract key discussion points, decisions made, and important topics",
      "taskType": "analysis",
      "actionType": "analyze",
      "executor": "shell",
      "dependsOn": ["collect-meeting-input"],
      "inputContext": "Meeting material",
      "targetArtifacts": ["key-points"],
      "expectedResult": "Key points and decisions extracted",
      "expectedOutputType": "summary",
      "acceptanceCriteria": ["Key points and decisions are extracted"],
      "evidence": ["key points documented"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Core meeting content"
    },
    {
      "id": "identify-action-items",
      "title": "Identify action items and owners",
      "description": "Extract action items, assignees, deadlines, and next steps from the meeting",
      "taskType": "analysis",
      "actionType": "analyze",
      "executor": "shell",
      "dependsOn": ["extract-key-points"],
      "inputContext": "Key points",
      "targetArtifacts": ["action-items"],
      "expectedResult": "Action items with owners identified",
      "expectedOutputType": "checklist",
      "acceptanceCriteria": ["Action items have owners and deadlines"],
      "evidence": ["action items documented"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Actionable next steps"
    },
    {
      "id": "organize-summary",
      "title": "Organize meeting summary",
      "description": "Structure the summary with clear sections: overview, discussion, decisions, action items, and next meeting",
      "taskType": "documentation",
      "actionType": "create",
      "executor": "shell",
      "dependsOn": ["identify-action-items"],
      "inputContext": "Key points, action items",
      "targetFiles": ["docs/"],
      "targetArtifacts": ["meeting-summary"],
      "expectedResult": "Organized meeting summary with all sections",
      "expectedOutputType": "summary",
      "acceptanceCriteria": ["Summary has all required sections"],
      "evidence": ["summary file exists"],
      "validationMethod": "file_exists",
      "riskLevel": "safe",
      "finalOutputContribution": "Structured meeting summary"
    },
    {
      "id": "review-and-finalize",
      "title": "Review and finalize summary",
      "description": "Review summary for accuracy, completeness, and clarity. Finalize for distribution",
      "taskType": "review",
      "actionType": "review",
      "executor": "shell",
      "dependsOn": ["organize-summary"],
      "inputContext": "Meeting summary draft",
      "targetFiles": ["docs/meeting-summary.md"],
      "targetArtifacts": ["final-summary"],
      "expectedResult": "Meeting summary reviewed and finalized",
      "expectedOutputType": "summary",
      "acceptanceCriteria": ["Summary is accurate and ready for distribution"],
      "evidence": ["summary finalized"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Final meeting deliverable"
    }
  ]
}
