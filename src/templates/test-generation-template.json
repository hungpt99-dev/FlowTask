{
  "id": "test-generation",
  "name": "Test Generation",
  "description": "Structured workflow for analyzing code and generating comprehensive tests",
  "workflowType": "test-generation",
  "category": "code",
  "version": "1.0",
  "tags": ["code", "test", "coverage"],
  "defaultMode": "auto",
  "estimatedDuration": "20min-1h",
  "typicalSteps": 7,
  "metadata": {
    "requiresScan": true,
    "requiresApproval": false,
    "requiresCodegraph": true,
    "outputTypes": ["file", "test_result", "report"]
  },
  "steps": [
    {
      "id": "read-project-rules",
      "title": "Read project rules and testing standards",
      "description": "Load project rules, testing conventions, and coverage requirements",
      "taskType": "general",
      "actionType": "read",
      "executor": "shell",
      "targetArtifacts": ["rules-review"],
      "expectedResult": "Testing standards reviewed",
      "acceptanceCriteria": ["Testing standards and conventions are reviewed"],
      "evidence": ["rules reviewed"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Ensures tests follow project conventions"
    },
    {
      "id": "analyze-code-to-test",
      "title": "Analyze code to be tested",
      "description": "Understand the code structure, functions, and modules that need test coverage using CodeGraph if available",
      "taskType": "coding",
      "actionType": "read",
      "executor": "shell",
      "dependsOn": ["read-project-rules"],
      "targetArtifacts": ["code-analysis"],
      "expectedResult": "Code to test analyzed with coverage targets identified",
      "expectedOutputType": "analysis",
      "acceptanceCriteria": ["Code analysis identifies test areas and coverage targets"],
      "evidence": ["analysis file exists"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Identifies what needs testing"
    },
    {
      "id": "design-test-strategy",
      "title": "Design test strategy",
      "description": "Plan test cases, edge cases, and testing approach based on code analysis",
      "taskType": "testing",
      "actionType": "analyze",
      "executor": "shell",
      "dependsOn": ["analyze-code-to-test"],
      "inputContext": "Code analysis, testing standards",
      "targetArtifacts": ["test-strategy"],
      "expectedResult": "Test strategy with test cases and edge cases",
      "expectedOutputType": "analysis",
      "acceptanceCriteria": ["Test strategy document exists with test cases documented"],
      "evidence": ["strategy file exists"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Blueprint for test implementation"
    },
    {
      "id": "implement-tests",
      "title": "Implement test cases",
      "description": "Write test implementations following project testing conventions and the test strategy",
      "taskType": "testing",
      "actionType": "create",
      "executor": "shell",
      "dependsOn": ["design-test-strategy"],
      "inputContext": "Test strategy, code to test",
      "targetFiles": ["tests/"],
      "targetArtifacts": ["test-files"],
      "expectedResult": "Test files with implemented test cases",
      "expectedOutputType": "file",
      "acceptanceCriteria": [
        "Test files exist with test cases",
        "Tests cover identified scenarios"
      ],
      "evidence": ["test files exist"],
      "validationMethod": "file_exists",
      "riskLevel": "safe",
      "retryPolicy": { "maxRetries": 2, "retryDelayMs": 1000 },
      "finalOutputContribution": "Core test implementation deliverable"
    },
    {
      "id": "run-test-suite",
      "title": "Run test suite",
      "description": "Execute the test suite to verify all tests pass",
      "taskType": "testing",
      "actionType": "execute",
      "executor": "shell",
      "dependsOn": ["implement-tests"],
      "inputContext": "Test files",
      "targetArtifacts": ["test-results"],
      "expectedResult": "Test suite runs and all tests pass",
      "expectedOutputType": "test_result",
      "acceptanceCriteria": ["Tests pass"],
      "evidence": ["exit code 0"],
      "verificationCommand": "",
      "validationMethod": "command_output",
      "riskLevel": "safe",
      "timeout": 180000,
      "finalOutputContribution": "Confirms tests are valid"
    },
    {
      "id": "fix-test-issues",
      "title": "Fix any test issues",
      "description": "Fix any failing tests or issues discovered during test execution",
      "taskType": "testing",
      "actionType": "modify",
      "executor": "shell",
      "dependsOn": ["run-test-suite"],
      "inputContext": "Test results, test files",
      "targetFiles": ["tests/"],
      "targetArtifacts": ["test-fixes"],
      "expectedResult": "All test issues fixed",
      "expectedOutputType": "file",
      "acceptanceCriteria": ["All tests pass after fixes"],
      "evidence": ["tests pass"],
      "validationMethod": "hybrid",
      "riskLevel": "safe",
      "retryPolicy": { "maxRetries": 2, "retryDelayMs": 1000 },
      "finalOutputContribution": "Ensures test quality"
    },
    {
      "id": "generate-report",
      "title": "Generate test report",
      "description": "Document test results, coverage, and any findings",
      "taskType": "documentation",
      "actionType": "generate",
      "executor": "shell",
      "dependsOn": ["fix-test-issues"],
      "inputContext": "Test results, code analysis",
      "targetFiles": ["reports/test-report.md"],
      "targetArtifacts": ["test-report"],
      "expectedResult": "Test report with results and coverage details",
      "expectedOutputType": "report",
      "acceptanceCriteria": ["Test report exists with results"],
      "evidence": ["report file exists"],
      "validationMethod": "file_exists",
      "riskLevel": "safe",
      "finalOutputContribution": "Documents testing outcomes"
    }
  ]
}
