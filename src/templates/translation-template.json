{
  "id": "translation",
  "name": "Translation",
  "description": "Structured workflow for translating content between languages with quality review",
  "workflowType": "translation",
  "category": "content",
  "version": "1.0",
  "tags": ["translation", "i18n", "language"],
  "defaultMode": "auto",
  "estimatedDuration": "15min-2h",
  "typicalSteps": 5,
  "metadata": {
    "requiresScan": true,
    "requiresApproval": false,
    "requiresCodegraph": false,
    "outputTypes": ["translation", "file", "document"]
  },
  "steps": [
    {
      "id": "understand-translation-scope",
      "title": "Understand translation scope",
      "description": "Identify source content, target languages, and translation requirements",
      "taskType": "general",
      "actionType": "analyze",
      "executor": "shell",
      "targetArtifacts": ["translation-requirements"],
      "expectedResult": "Translation scope and requirements defined",
      "expectedOutputType": "analysis",
      "acceptanceCriteria": ["Source, target languages, and requirements are defined"],
      "evidence": ["requirements file exists"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Defines translation scope"
    },
    {
      "id": "extract-source-content",
      "title": "Extract source content",
      "description": "Identify and extract source content files or text segments for translation",
      "taskType": "general",
      "actionType": "read",
      "executor": "shell",
      "dependsOn": ["understand-translation-scope"],
      "inputContext": "Translation requirements",
      "targetFiles": [],
      "targetArtifacts": ["source-content"],
      "expectedResult": "Source content extracted for translation",
      "expectedOutputType": "file",
      "acceptanceCriteria": ["Source content is identified and extracted"],
      "evidence": ["source content extracted"],
      "validationMethod": "file_exists",
      "riskLevel": "safe",
      "finalOutputContribution": "What needs to be translated"
    },
    {
      "id": "translate-content",
      "title": "Translate content",
      "description": "Translate the source content to target languages preserving meaning, tone, and context",
      "taskType": "writing",
      "actionType": "transform",
      "executor": "shell",
      "dependsOn": ["extract-source-content"],
      "inputContext": "Source content, requirements",
      "targetFiles": [],
      "targetArtifacts": ["translated-content"],
      "expectedResult": "Content translated to target languages",
      "expectedOutputType": "translation",
      "acceptanceCriteria": ["Content is translated preserving meaning and tone"],
      "evidence": ["translated files exist"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "retryPolicy": { "maxRetries": 2, "retryDelayMs": 1000 },
      "timeout": 300000,
      "finalOutputContribution": "Core translation deliverable"
    },
    {
      "id": "review-translation",
      "title": "Review translation quality",
      "description": "Review translation for accuracy, fluency, cultural appropriateness, and terminology consistency",
      "taskType": "review",
      "actionType": "review",
      "executor": "shell",
      "dependsOn": ["translate-content"],
      "inputContext": "Translated content, source content",
      "targetFiles": [],
      "targetArtifacts": ["translation-review"],
      "expectedResult": "Translation reviewed and issues corrected",
      "expectedOutputType": "translation",
      "acceptanceCriteria": ["Translation is accurate, fluent, and culturally appropriate"],
      "evidence": ["review completed"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Quality assurance for translation"
    },
    {
      "id": "finalize-translation",
      "title": "Finalize and deliver translation",
      "description": "Apply review feedback, format correctly, and produce final translated files",
      "taskType": "general",
      "actionType": "modify",
      "executor": "shell",
      "dependsOn": ["review-translation"],
      "inputContext": "Reviewed translation",
      "targetFiles": [],
      "targetArtifacts": ["final-translation"],
      "expectedResult": "Final translation ready for delivery",
      "expectedOutputType": "translation",
      "acceptanceCriteria": ["Final translation is complete and ready"],
      "evidence": ["final translation files exist"],
      "validationMethod": "file_exists",
      "riskLevel": "safe",
      "finalOutputContribution": "Final translation deliverable"
    }
  ]
}
