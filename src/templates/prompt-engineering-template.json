{
  "id": "prompt-engineering",
  "name": "Prompt Engineering",
  "description": "Structured workflow for designing, testing, and refining AI prompts",
  "workflowType": "prompt-engineering",
  "category": "ai",
  "version": "1.0",
  "tags": ["prompt", "ai", "engineering", "testing"],
  "defaultMode": "auto",
  "estimatedDuration": "20min-2h",
  "typicalSteps": 6,
  "metadata": {
    "requiresScan": false,
    "requiresApproval": false,
    "requiresCodegraph": false,
    "outputTypes": ["file", "report", "analysis", "recommendation"]
  },
  "steps": [
    {
      "id": "understand-prompt-goal",
      "title": "Understand prompt goal",
      "description": "Analyze the objective, target model, expected output format, and constraints for the prompt",
      "taskType": "analysis",
      "actionType": "analyze",
      "executor": "shell",
      "targetArtifacts": ["prompt-goals"],
      "expectedResult": "Prompt goals and constraints documented",
      "expectedOutputType": "analysis",
      "acceptanceCriteria": ["Prompt goal, format, and constraints are defined"],
      "evidence": ["goals document exists"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Defines prompt design targets"
    },
    {
      "id": "design-initial-prompt",
      "title": "Design initial prompt",
      "description": "Create the initial prompt with clear instructions, context, format specification, and examples",
      "taskType": "general",
      "actionType": "create",
      "executor": "shell",
      "dependsOn": ["understand-prompt-goal"],
      "inputContext": "Prompt goals",
      "targetFiles": ["prompts/"],
      "targetArtifacts": ["initial-prompt"],
      "expectedResult": "Initial prompt designed",
      "expectedOutputType": "file",
      "acceptanceCriteria": ["Initial prompt follows prompt engineering best practices"],
      "evidence": ["prompt file exists"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "retryPolicy": { "maxRetries": 2, "retryDelayMs": 1000 },
      "finalOutputContribution": "First version of the prompt"
    },
    {
      "id": "test-prompt",
      "title": "Test prompt with sample inputs",
      "description": "Run the prompt with test inputs to evaluate output quality, consistency, and correctness",
      "taskType": "testing",
      "actionType": "execute",
      "executor": "shell",
      "dependsOn": ["design-initial-prompt"],
      "inputContext": "Initial prompt, test inputs",
      "targetArtifacts": ["test-results"],
      "expectedResult": "Prompt tested and results documented",
      "expectedOutputType": "test_result",
      "acceptanceCriteria": ["Test results are documented with observations"],
      "evidence": ["test results exist"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "timeout": 120000,
      "finalOutputContribution": "Performance data for refinement"
    },
    {
      "id": "analyze-and-refine",
      "title": "Analyze results and refine prompt",
      "description": "Evaluate test outputs against goals, identify issues, and refine the prompt",
      "taskType": "analysis",
      "actionType": "analyze",
      "executor": "shell",
      "dependsOn": ["test-prompt"],
      "inputContext": "Test results, prompt goals",
      "targetFiles": ["prompts/"],
      "targetArtifacts": ["refined-prompt"],
      "expectedResult": "Prompt refined based on test results",
      "expectedOutputType": "file",
      "acceptanceCriteria": ["Prompt is refined to address identified issues"],
      "evidence": ["refined prompt exists"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "retryPolicy": { "maxRetries": 3, "retryDelayMs": 1000 },
      "finalOutputContribution": "Improved prompt version"
    },
    {
      "id": "validate-prompt",
      "title": "Validate final prompt",
      "description": "Run final validation tests to confirm the prompt meets all requirements and produces expected outputs",
      "taskType": "validation",
      "actionType": "validate",
      "executor": "shell",
      "dependsOn": ["analyze-and-refine"],
      "inputContext": "Refined prompt, goals",
      "targetArtifacts": ["validation-results"],
      "expectedResult": "Final prompt validated",
      "expectedOutputType": "report",
      "acceptanceCriteria": ["Prompt meets all defined goals and constraints"],
      "evidence": ["validation passes"],
      "validationMethod": "hybrid",
      "riskLevel": "safe",
      "finalOutputContribution": "Confirms prompt quality"
    },
    {
      "id": "document-prompt",
      "title": "Document final prompt",
      "description": "Document the final prompt, design decisions, usage instructions, and expected outputs",
      "taskType": "documentation",
      "actionType": "generate",
      "executor": "shell",
      "dependsOn": ["validate-prompt"],
      "inputContext": "Final prompt, test results, design notes",
      "targetFiles": ["prompts/final-prompt.md"],
      "targetArtifacts": ["prompt-documentation"],
      "expectedResult": "Final prompt documented with usage notes",
      "expectedOutputType": "file",
      "acceptanceCriteria": ["Final prompt and usage documentation exist"],
      "evidence": ["documentation file exists"],
      "validationMethod": "file_exists",
      "riskLevel": "safe",
      "finalOutputContribution": "Final prompt deliverable"
    }
  ]
}
