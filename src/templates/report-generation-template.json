{
  "id": "report-generation",
  "name": "Report Generation",
  "description": "Structured workflow for gathering information and generating comprehensive reports",
  "workflowType": "report-generation",
  "category": "content",
  "version": "1.0",
  "tags": ["report", "documentation", "summary"],
  "defaultMode": "auto",
  "estimatedDuration": "20min-2h",
  "typicalSteps": 6,
  "metadata": {
    "requiresScan": true,
    "requiresApproval": false,
    "requiresCodegraph": false,
    "outputTypes": ["report", "summary", "file"]
  },
  "steps": [
    {
      "id": "understand-report-requirements",
      "title": "Understand report requirements",
      "description": "Define report purpose, audience, scope, and required sections",
      "taskType": "analysis",
      "actionType": "analyze",
      "executor": "shell",
      "targetArtifacts": ["report-requirements"],
      "expectedResult": "Report requirements and scope defined",
      "expectedOutputType": "analysis",
      "acceptanceCriteria": ["Report scope, audience, and sections are defined"],
      "evidence": ["requirements file exists"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Defines what the report should contain"
    },
    {
      "id": "gather-information",
      "title": "Gather information and data",
      "description": "Collect relevant information, data, and context needed for the report",
      "taskType": "research",
      "actionType": "read",
      "executor": "shell",
      "dependsOn": ["understand-report-requirements"],
      "inputContext": "Report requirements",
      "targetArtifacts": ["gathered-information"],
      "expectedResult": "Information gathered for the report",
      "expectedOutputType": "research_result",
      "acceptanceCriteria": ["Information covers all report sections"],
      "evidence": ["information gathered"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Raw material for the report"
    },
    {
      "id": "outline-report",
      "title": "Outline report structure",
      "description": "Create a detailed outline with sections, subsections, and key content points",
      "taskType": "documentation",
      "actionType": "create",
      "executor": "shell",
      "dependsOn": ["gather-information"],
      "inputContext": "Requirements, gathered information",
      "targetArtifacts": ["report-outline"],
      "expectedResult": "Report outline with structured sections",
      "expectedOutputType": "document",
      "acceptanceCriteria": ["Outline exists with structured sections"],
      "evidence": ["outline file exists"],
      "validationMethod": "file_exists",
      "riskLevel": "safe",
      "finalOutputContribution": "Blueprint for the report"
    },
    {
      "id": "write-report",
      "title": "Write report content",
      "description": "Write the full report content following the outline and including all required information",
      "taskType": "documentation",
      "actionType": "generate",
      "executor": "shell",
      "dependsOn": ["outline-report"],
      "inputContext": "Outline, gathered information",
      "targetFiles": ["reports/"],
      "targetArtifacts": ["report-draft"],
      "expectedResult": "Report written with complete content",
      "expectedOutputType": "report",
      "acceptanceCriteria": ["Report covers all required sections with complete content"],
      "evidence": ["report draft exists"],
      "validationMethod": "file_exists",
      "riskLevel": "safe",
      "retryPolicy": { "maxRetries": 2, "retryDelayMs": 1000 },
      "timeout": 300000,
      "finalOutputContribution": "Core report deliverable"
    },
    {
      "id": "review-and-refine",
      "title": "Review and refine report",
      "description": "Review report for clarity, accuracy, completeness, and quality",
      "taskType": "review",
      "actionType": "review",
      "executor": "shell",
      "dependsOn": ["write-report"],
      "inputContext": "Report draft, requirements",
      "targetFiles": ["reports/"],
      "targetArtifacts": ["review-notes"],
      "expectedResult": "Report reviewed and refined",
      "expectedOutputType": "report",
      "acceptanceCriteria": ["Report is reviewed and issues are addressed"],
      "evidence": ["review completed"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Ensures report quality"
    },
    {
      "id": "finalize-report",
      "title": "Finalize and deliver report",
      "description": "Finalize report formatting, verify completeness, and prepare final deliverable",
      "taskType": "documentation",
      "actionType": "generate",
      "executor": "shell",
      "dependsOn": ["review-and-refine"],
      "inputContext": "Reviewed report",
      "targetFiles": ["reports/final-report.md"],
      "targetArtifacts": ["final-report"],
      "expectedResult": "Final report ready for delivery",
      "expectedOutputType": "report",
      "acceptanceCriteria": ["Final report is complete and ready"],
      "evidence": ["final report file exists"],
      "validationMethod": "file_exists",
      "riskLevel": "safe",
      "finalOutputContribution": "Final report deliverable"
    }
  ]
}
