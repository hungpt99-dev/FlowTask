{
  "id": "refactor",
  "name": "Code Refactoring",
  "description": "Structured workflow for safely refactoring code with change analysis, implementation, and regression testing",
  "workflowType": "refactor",
  "category": "code",
  "version": "1.0",
  "tags": ["code", "refactor", "improvement"],
  "defaultMode": "auto",
  "estimatedDuration": "30min-3h",
  "typicalSteps": 7,
  "metadata": {
    "requiresScan": true,
    "requiresApproval": true,
    "requiresCodegraph": true,
    "outputTypes": ["code_change", "report", "test_result"]
  },
  "steps": [
    {
      "id": "read-project-rules",
      "title": "Read project rules and conventions",
      "description": "Load project rules, coding standards, and refactoring guidelines",
      "taskType": "general",
      "actionType": "read",
      "executor": "shell",
      "targetArtifacts": ["rules-review"],
      "expectedResult": "Project rules reviewed",
      "acceptanceCriteria": ["Project rules files are reviewed"],
      "evidence": ["rules reviewed"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Ensures refactoring follows project standards"
    },
    {
      "id": "understand-refactor-scope",
      "title": "Understand refactoring scope",
      "description": "Analyze what needs to be refactored and define the scope, goals, and success criteria",
      "taskType": "analysis",
      "actionType": "analyze",
      "executor": "shell",
      "dependsOn": ["read-project-rules"],
      "targetArtifacts": ["refactor-scope"],
      "expectedResult": "Refactoring scope and goals defined",
      "expectedOutputType": "analysis",
      "acceptanceCriteria": ["Refactoring scope and goals are documented"],
      "evidence": ["scope document exists"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Defines what the refactoring aims to achieve"
    },
    {
      "id": "analyze-impact",
      "title": "Analyze impact and dependencies",
      "description": "Use CodeGraph if available to trace impact of changes, identify all dependent modules, and assess risk",
      "taskType": "coding",
      "actionType": "analyze",
      "executor": "shell",
      "dependsOn": ["understand-refactor-scope"],
      "inputContext": "Refactoring scope, project structure",
      "targetFiles": [],
      "targetArtifacts": ["impact-analysis"],
      "expectedResult": "Impact analysis with all affected files documented",
      "expectedOutputType": "analysis",
      "acceptanceCriteria": ["Impact analysis covers all affected files"],
      "evidence": ["impact analysis exists"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Prevents unexpected breakage from refactoring"
    },
    {
      "id": "implement-refactor",
      "title": "Implement refactoring changes",
      "description": "Apply the refactoring changes following the plan, preserving behavior while improving structure",
      "taskType": "coding",
      "actionType": "modify",
      "executor": "shell",
      "dependsOn": ["analyze-impact"],
      "inputContext": "Impact analysis, refactoring scope",
      "targetFiles": ["src/"],
      "targetArtifacts": ["refactor-changes"],
      "expectedResult": "Refactoring changes applied correctly",
      "expectedOutputType": "code_change",
      "acceptanceCriteria": ["Refactoring changes are applied to the right files"],
      "evidence": ["files changed"],
      "validationMethod": "hybrid",
      "approvalRequired": true,
      "riskLevel": "risky",
      "retryPolicy": { "maxRetries": 2, "retryDelayMs": 2000 },
      "timeout": 300000,
      "finalOutputContribution": "Core refactoring deliverable"
    },
    {
      "id": "run-tests",
      "title": "Run tests and validation",
      "description": "Execute the full test suite to verify no regressions were introduced by the refactoring",
      "taskType": "testing",
      "actionType": "validate",
      "executor": "shell",
      "dependsOn": ["implement-refactor"],
      "inputContext": "Refactoring changes",
      "targetArtifacts": ["test-results"],
      "expectedResult": "All existing tests continue to pass",
      "expectedOutputType": "test_result",
      "acceptanceCriteria": ["All tests pass after refactoring"],
      "evidence": ["exit code 0"],
      "verificationCommand": "",
      "validationMethod": "command_output",
      "approvalRequired": false,
      "riskLevel": "safe",
      "timeout": 180000,
      "finalOutputContribution": "Confirms refactoring is safe"
    },
    {
      "id": "fix-issues",
      "title": "Fix any issues",
      "description": "Address any failing tests, lint errors, or type errors introduced by the refactoring",
      "taskType": "coding",
      "actionType": "modify",
      "executor": "shell",
      "dependsOn": ["run-tests"],
      "inputContext": "Test results, refactoring changes",
      "targetFiles": ["src/", "tests/"],
      "targetArtifacts": ["fix-changes"],
      "expectedResult": "All issues fixed and tests pass",
      "expectedOutputType": "code_change",
      "acceptanceCriteria": ["All test and validation issues are resolved"],
      "evidence": ["issues resolved"],
      "validationMethod": "hybrid",
      "riskLevel": "safe",
      "retryPolicy": { "maxRetries": 2, "retryDelayMs": 1000 },
      "finalOutputContribution": "Ensures final quality after refactoring"
    },
    {
      "id": "generate-report",
      "title": "Generate refactoring report",
      "description": "Document what was refactored, why, and the validation results",
      "taskType": "documentation",
      "actionType": "generate",
      "executor": "shell",
      "dependsOn": ["fix-issues"],
      "inputContext": "All previous step outputs",
      "targetFiles": ["reports/refactor-report.md"],
      "targetArtifacts": ["refactor-report"],
      "expectedResult": "Refactoring report with summary of changes",
      "expectedOutputType": "report",
      "acceptanceCriteria": ["Refactor report exists with change summary"],
      "evidence": ["report file exists"],
      "validationMethod": "file_exists",
      "riskLevel": "safe",
      "finalOutputContribution": "Documents the refactoring for the team"
    }
  ]
}
