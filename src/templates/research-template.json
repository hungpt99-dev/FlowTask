{
  "id": "research",
  "name": "Research",
  "description": "Structured workflow for investigating topics, gathering information, analyzing findings, and producing research reports",
  "workflowType": "research",
  "category": "analysis",
  "version": "1.0",
  "tags": ["research", "analysis", "investigation"],
  "defaultMode": "auto",
  "estimatedDuration": "30min-3h",
  "typicalSteps": 6,
  "metadata": {
    "requiresScan": true,
    "requiresApproval": false,
    "requiresCodegraph": false,
    "outputTypes": ["research_result", "analysis", "report", "recommendation"]
  },
  "steps": [
    {
      "id": "define-research-questions",
      "title": "Define research questions",
      "description": "Clarify the specific questions the research should answer and scope of investigation",
      "taskType": "research",
      "actionType": "analyze",
      "executor": "shell",
      "targetArtifacts": ["research-questions"],
      "expectedResult": "Research questions clearly defined",
      "expectedOutputType": "analysis",
      "acceptanceCriteria": ["Research questions are clearly defined"],
      "evidence": ["questions file exists"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Focuses the research effort"
    },
    {
      "id": "review-existing-knowledge",
      "title": "Review existing knowledge and context",
      "description": "Review existing project files, documentation, and context relevant to the research topic",
      "taskType": "research",
      "actionType": "read",
      "executor": "shell",
      "dependsOn": ["define-research-questions"],
      "inputContext": "Research questions",
      "targetArtifacts": ["context-summary"],
      "expectedResult": "Existing knowledge and context reviewed",
      "expectedOutputType": "analysis",
      "acceptanceCriteria": ["Existing relevant context has been reviewed"],
      "evidence": ["context reviewed"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Builds on existing knowledge"
    },
    {
      "id": "gather-information",
      "title": "Gather information",
      "description": "Collect relevant information from project files, documentation, external sources if available, and data",
      "taskType": "research",
      "actionType": "investigate",
      "executor": "shell",
      "dependsOn": ["review-existing-knowledge"],
      "inputContext": "Research questions, existing context",
      "targetArtifacts": ["research-findings"],
      "expectedResult": "Information gathered from identified sources",
      "expectedOutputType": "research_result",
      "acceptanceCriteria": ["Information gathered covers research questions"],
      "evidence": ["findings file exists"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "retryPolicy": { "maxRetries": 2, "retryDelayMs": 1000 },
      "finalOutputContribution": "Raw material for analysis"
    },
    {
      "id": "analyze-findings",
      "title": "Analyze findings",
      "description": "Analyze gathered information, identify patterns, draw conclusions, and assess source quality",
      "taskType": "research",
      "actionType": "analyze",
      "executor": "shell",
      "dependsOn": ["gather-information"],
      "inputContext": "Research findings, questions",
      "targetArtifacts": ["analysis-document"],
      "expectedResult": "Findings analyzed with documented conclusions",
      "expectedOutputType": "analysis",
      "acceptanceCriteria": ["Findings are analyzed with documented conclusions"],
      "evidence": ["analysis exists"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Transforms raw findings into insights"
    },
    {
      "id": "document-results",
      "title": "Document results and recommendations",
      "description": "Document research findings, comparisons, analysis, and actionable recommendations",
      "taskType": "research",
      "actionType": "generate",
      "executor": "shell",
      "dependsOn": ["analyze-findings"],
      "inputContext": "Analysis, findings",
      "targetArtifacts": ["research-results"],
      "expectedResult": "Research results documented with recommendations",
      "expectedOutputType": "recommendation",
      "acceptanceCriteria": ["Results include findings and recommendations"],
      "evidence": ["results file exists"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Actionable research output"
    },
    {
      "id": "generate-report",
      "title": "Generate research report",
      "description": "Create a comprehensive research report with methodology, findings, conclusions, and recommendations",
      "taskType": "documentation",
      "actionType": "generate",
      "executor": "shell",
      "dependsOn": ["document-results"],
      "inputContext": "All research outputs",
      "targetFiles": ["reports/research-report.md"],
      "targetArtifacts": ["research-report"],
      "expectedResult": "Research report with findings and recommendations",
      "expectedOutputType": "report",
      "acceptanceCriteria": ["Research report exists with findings"],
      "evidence": ["report file exists"],
      "validationMethod": "file_exists",
      "riskLevel": "safe",
      "finalOutputContribution": "Final research deliverable"
    }
  ]
}
