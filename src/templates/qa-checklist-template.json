{
  "id": "qa-checklist",
  "name": "Quality Assurance Checklist",
  "description": "Structured workflow for running QA checks, generating test scenarios, and validating acceptance criteria",
  "workflowType": "qa-checklist",
  "category": "quality",
  "version": "1.0",
  "tags": ["qa", "testing", "quality", "validation"],
  "defaultMode": "auto",
  "estimatedDuration": "20min-2h",
  "typicalSteps": 6,
  "metadata": {
    "requiresScan": true,
    "requiresApproval": false,
    "requiresCodegraph": false,
    "outputTypes": ["checklist", "report", "analysis", "test_result"]
  },
  "steps": [
    {
      "id": "understand-qa-scope",
      "title": "Understand QA scope",
      "description": "Analyze what needs quality assurance review and define QA scope and objectives",
      "taskType": "qa",
      "actionType": "analyze",
      "executor": "shell",
      "targetArtifacts": ["qa-scope"],
      "expectedResult": "QA scope and objectives defined",
      "expectedOutputType": "analysis",
      "acceptanceCriteria": ["QA scope and objectives are documented"],
      "evidence": ["scope document exists"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Defines QA coverage"
    },
    {
      "id": "review-changes",
      "title": "Review changes under test",
      "description": "Review the changes, features, or deliverables that need QA verification",
      "taskType": "qa",
      "actionType": "read",
      "executor": "shell",
      "dependsOn": ["understand-qa-scope"],
      "inputContext": "QA scope",
      "targetArtifacts": ["changes-review"],
      "expectedResult": "Changes reviewed for QA coverage",
      "expectedOutputType": "analysis",
      "acceptanceCriteria": ["All relevant changes are reviewed"],
      "evidence": ["review completed"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Identifies what to test"
    },
    {
      "id": "generate-test-scenarios",
      "title": "Generate test scenarios",
      "description": "Create comprehensive test scenarios, edge cases, and test data requirements",
      "taskType": "qa",
      "actionType": "generate",
      "executor": "shell",
      "dependsOn": ["review-changes"],
      "inputContext": "Changes review, QA scope",
      "targetArtifacts": ["test-scenarios"],
      "expectedResult": "Test scenarios covering all changes",
      "expectedOutputType": "checklist",
      "acceptanceCriteria": ["Test scenarios cover functional and edge cases"],
      "evidence": ["scenarios file exists"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Test coverage plan"
    },
    {
      "id": "validate-acceptance-criteria",
      "title": "Validate acceptance criteria",
      "description": "Verify all acceptance criteria are met and traceable to specific tests",
      "taskType": "validation",
      "actionType": "validate",
      "executor": "shell",
      "dependsOn": ["generate-test-scenarios"],
      "inputContext": "Test scenarios, acceptance criteria",
      "targetArtifacts": ["criteria-validation"],
      "expectedResult": "Acceptance criteria validation completed",
      "expectedOutputType": "report",
      "acceptanceCriteria": ["All acceptance criteria are validated"],
      "evidence": ["criteria validated"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Confirms requirements met"
    },
    {
      "id": "execute-qa-checks",
      "title": "Execute QA checks",
      "description": "Run defined test scenarios and QA validation checks",
      "taskType": "qa",
      "actionType": "execute",
      "executor": "shell",
      "dependsOn": ["validate-acceptance-criteria"],
      "inputContext": "Test scenarios, changes",
      "targetArtifacts": ["qa-results"],
      "expectedResult": "QA checks executed with results documented",
      "expectedOutputType": "test_result",
      "acceptanceCriteria": ["All QA checks pass or issues documented"],
      "evidence": ["qa completed"],
      "validationMethod": "command_output",
      "riskLevel": "safe",
      "timeout": 300000,
      "finalOutputContribution": "QA execution results"
    },
    {
      "id": "generate-qa-report",
      "title": "Generate QA report",
      "description": "Document QA results, defect summary, risk assessment, and quality recommendations",
      "taskType": "documentation",
      "actionType": "generate",
      "executor": "shell",
      "dependsOn": ["execute-qa-checks"],
      "inputContext": "QA results, scenarios, scope",
      "targetFiles": ["reports/qa-report.md"],
      "targetArtifacts": ["qa-report"],
      "expectedResult": "QA report with results and recommendations",
      "expectedOutputType": "report",
      "acceptanceCriteria": ["QA report exists with results"],
      "evidence": ["report file exists"],
      "validationMethod": "file_exists",
      "riskLevel": "safe",
      "finalOutputContribution": "Final QA deliverable"
    }
  ]
}
