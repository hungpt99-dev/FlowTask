{
  "id": "mixed",
  "name": "Mixed Workflow",
  "description": "Flexible workflow for complex tasks that span multiple domains including code, documentation, data, research, and operations",
  "workflowType": "mixed",
  "category": "general",
  "version": "1.0",
  "tags": ["mixed", "complex", "multi-domain"],
  "defaultMode": "auto",
  "estimatedDuration": "varies",
  "typicalSteps": 8,
  "metadata": {
    "requiresScan": true,
    "requiresApproval": false,
    "requiresCodegraph": false,
    "outputTypes": ["mixed_artifact", "report", "file", "analysis"]
  },
  "steps": [
    {
      "id": "scan-all-contexts",
      "title": "Scan all relevant contexts",
      "description": "Perform comprehensive scan across code, documentation, data files, configs, and other relevant sources",
      "taskType": "general",
      "actionType": "read",
      "executor": "shell",
      "targetArtifacts": ["comprehensive-scan"],
      "expectedResult": "All relevant contexts scanned",
      "expectedOutputType": "analysis",
      "acceptanceCriteria": ["All relevant contexts are scanned and summarized"],
      "evidence": ["scan completed"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Comprehensive context for planning"
    },
    {
      "id": "understand-multi-domain-requirements",
      "title": "Understand multi-domain requirements",
      "description": "Analyze requirements across all involved domains: code, docs, data, research, operations, etc.",
      "taskType": "analysis",
      "actionType": "analyze",
      "executor": "shell",
      "dependsOn": ["scan-all-contexts"],
      "inputContext": "Comprehensive scan results",
      "targetArtifacts": ["multi-domain-requirements"],
      "expectedResult": "Multi-domain requirements documented",
      "expectedOutputType": "analysis",
      "acceptanceCriteria": ["Requirements cover all involved domains"],
      "evidence": ["requirements exist"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Cross-domain requirements"
    },
    {
      "id": "create-multi-step-plan",
      "title": "Create multi-domain execution plan",
      "description": "Design a plan that covers all domains with correct sequencing, dependencies, and expected interleaving",
      "taskType": "analysis",
      "actionType": "analyze",
      "executor": "shell",
      "dependsOn": ["understand-multi-domain-requirements"],
      "inputContext": "Requirements, scan results",
      "targetArtifacts": ["execution-plan"],
      "expectedResult": "Multi-domain execution plan created",
      "expectedOutputType": "report",
      "acceptanceCriteria": ["Plan covers all domains with correct dependencies"],
      "evidence": ["plan exists"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Cross-domain execution roadmap"
    },
    {
      "id": "execute-domain-work",
      "title": "Execute domain-specific work",
      "description": "Carry out the planned work across all domains: code changes, documentation, data processing, research, etc.",
      "taskType": "general",
      "actionType": "execute",
      "executor": "shell",
      "dependsOn": ["create-multi-step-plan"],
      "inputContext": "Execution plan",
      "targetFiles": [],
      "targetArtifacts": ["domain-outputs"],
      "expectedResult": "All domain work completed per plan",
      "expectedOutputType": "mixed_artifact",
      "acceptanceCriteria": ["Work is completed across all domains per plan"],
      "evidence": ["domain outputs exist"],
      "validationMethod": "hybrid",
      "riskLevel": "safe",
      "retryPolicy": { "maxRetries": 2, "retryDelayMs": 1000 },
      "timeout": 600000,
      "finalOutputContribution": "Core multi-domain deliverables"
    },
    {
      "id": "cross-validate-outputs",
      "title": "Cross-validate outputs across domains",
      "description": "Verify that work across domains is consistent, compatible, and meets overall objectives",
      "taskType": "validation",
      "actionType": "validate",
      "executor": "shell",
      "dependsOn": ["execute-domain-work"],
      "inputContext": "Domain outputs, requirements",
      "targetArtifacts": ["cross-validation-results"],
      "expectedResult": "Cross-domain validation completed",
      "expectedOutputType": "report",
      "acceptanceCriteria": ["Outputs are consistent across all domains"],
      "evidence": ["validation completed"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Ensures cross-domain coherence"
    },
    {
      "id": "fix-cross-domain-issues",
      "title": "Fix cross-domain issues",
      "description": "Address any inconsistencies, conflicts, or gaps found during cross-domain validation",
      "taskType": "general",
      "actionType": "modify",
      "executor": "shell",
      "dependsOn": ["cross-validate-outputs"],
      "inputContext": "Validation results, domain outputs",
      "targetFiles": [],
      "targetArtifacts": ["cross-domain-fixes"],
      "expectedResult": "Cross-domain issues resolved",
      "expectedOutputType": "mixed_artifact",
      "acceptanceCriteria": ["All cross-domain issues are resolved"],
      "evidence": ["issues resolved"],
      "validationMethod": "hybrid",
      "riskLevel": "safe",
      "retryPolicy": { "maxRetries": 2, "retryDelayMs": 1000 },
      "finalOutputContribution": "Final cross-domain quality"
    },
    {
      "id": "run-unified-validation",
      "title": "Run unified validation",
      "description": "Run all applicable validation checks across all domains to confirm overall quality",
      "taskType": "validation",
      "actionType": "validate",
      "executor": "shell",
      "dependsOn": ["fix-cross-domain-issues"],
      "inputContext": "All outputs and fixes",
      "targetArtifacts": ["unified-validation"],
      "expectedResult": "All validation checks pass",
      "expectedOutputType": "report",
      "acceptanceCriteria": ["All domain-specific and cross-domain checks pass"],
      "evidence": ["validation passes"],
      "validationMethod": "hybrid",
      "riskLevel": "safe",
      "timeout": 300000,
      "finalOutputContribution": "Confirms overall quality"
    },
    {
      "id": "generate-comprehensive-report",
      "title": "Generate comprehensive report",
      "description": "Produce a unified final report covering all domains, cross-domain insights, validation results, and next steps",
      "taskType": "documentation",
      "actionType": "generate",
      "executor": "shell",
      "dependsOn": ["run-unified-validation"],
      "inputContext": "All workflow outputs",
      "targetFiles": ["reports/final-report.md"],
      "targetArtifacts": ["final-report"],
      "expectedResult": "Comprehensive final report produced",
      "expectedOutputType": "report",
      "acceptanceCriteria": ["Final report covers all domains and results"],
      "evidence": ["report file exists"],
      "validationMethod": "file_exists",
      "riskLevel": "safe",
      "finalOutputContribution": "Final workflow deliverable"
    }
  ]
}
