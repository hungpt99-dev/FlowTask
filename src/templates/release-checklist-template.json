{
  "id": "release-checklist",
  "name": "Release Checklist",
  "description": "Structured workflow for preparing, validating, and executing software releases",
  "workflowType": "release-checklist",
  "category": "operations",
  "version": "1.0",
  "tags": ["release", "deploy", "operations"],
  "defaultMode": "manual",
  "estimatedDuration": "30min-2h",
  "typicalSteps": 7,
  "metadata": {
    "requiresScan": true,
    "requiresApproval": true,
    "requiresCodegraph": false,
    "outputTypes": ["checklist", "report", "config_change", "log_output"]
  },
  "steps": [
    {
      "id": "understand-release-scope",
      "title": "Understand release scope",
      "description": "Define release scope, version, and what is included in this release",
      "taskType": "release",
      "actionType": "analyze",
      "executor": "shell",
      "targetArtifacts": ["release-scope"],
      "expectedResult": "Release scope and version defined",
      "expectedOutputType": "analysis",
      "acceptanceCriteria": ["Release scope and version are documented"],
      "evidence": ["scope document exists"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Defines release boundaries"
    },
    {
      "id": "review-changelog",
      "title": "Review changes and changelog",
      "description": "Review all changes since last release, update changelog, and verify version bump",
      "taskType": "release",
      "actionType": "read",
      "executor": "shell",
      "dependsOn": ["understand-release-scope"],
      "inputContext": "Release scope",
      "targetFiles": ["CHANGELOG.md"],
      "targetArtifacts": ["changelog-review"],
      "expectedResult": "Changes reviewed and changelog updated",
      "expectedOutputType": "report",
      "acceptanceCriteria": ["Changelog is updated with all changes"],
      "evidence": ["changelog updated"],
      "validationMethod": "file_diff",
      "riskLevel": "safe",
      "finalOutputContribution": "Records release changes"
    },
    {
      "id": "run-validation",
      "title": "Run pre-release validation",
      "description": "Run tests, lint, type checks, build, and all validation gates",
      "taskType": "validation",
      "actionType": "validate",
      "executor": "shell",
      "dependsOn": ["review-changelog"],
      "inputContext": "Release scope",
      "targetArtifacts": ["validation-results"],
      "expectedResult": "All validation gates pass",
      "expectedOutputType": "test_result",
      "acceptanceCriteria": ["Tests pass", "Build succeeds", "Lint passes"],
      "evidence": ["exit code 0"],
      "verificationCommand": "",
      "validationMethod": "command_output",
      "riskLevel": "safe",
      "timeout": 300000,
      "finalOutputContribution": "Confirms release readiness"
    },
    {
      "id": "perform-risk-review",
      "title": "Perform risk review",
      "description": "Review rollout risks, failure scenarios, and rollback plan",
      "taskType": "release",
      "actionType": "analyze",
      "executor": "shell",
      "dependsOn": ["run-validation"],
      "inputContext": "Validation results, scope",
      "targetArtifacts": ["risk-review"],
      "expectedResult": "Risks reviewed with mitigation plan",
      "expectedOutputType": "analysis",
      "acceptanceCriteria": ["Risks are assessed and rollback plan defined"],
      "evidence": ["risk review exists"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Risk awareness for release"
    },
    {
      "id": "prepare-deployment",
      "title": "Prepare deployment artifacts",
      "description": "Build release artifacts, update version files, and prepare deployment configuration",
      "taskType": "operations",
      "actionType": "create",
      "executor": "shell",
      "dependsOn": ["perform-risk-review"],
      "inputContext": "Validation results, scope",
      "targetFiles": [],
      "targetArtifacts": ["deployment-artifacts"],
      "expectedResult": "Deployment artifacts ready",
      "expectedOutputType": "config_change",
      "acceptanceCriteria": ["Build succeeds and deployment artifacts exist"],
      "evidence": ["build completed"],
      "validationMethod": "command_output",
      "approvalRequired": true,
      "riskLevel": "risky",
      "retryPolicy": { "maxRetries": 1, "retryDelayMs": 5000 },
      "timeout": 600000,
      "finalOutputContribution": "Deployment package"
    },
    {
      "id": "execute-deployment",
      "title": "Execute deployment",
      "description": "Execute the release deployment to target environment with monitoring",
      "taskType": "operations",
      "actionType": "execute",
      "executor": "shell",
      "dependsOn": ["prepare-deployment"],
      "inputContext": "Deployment artifacts, risk review",
      "targetArtifacts": ["deployment-logs"],
      "expectedResult": "Deployment completed successfully",
      "expectedOutputType": "log_output",
      "acceptanceCriteria": ["Deployment completes successfully"],
      "evidence": ["deployment succeeded"],
      "validationMethod": "command_output",
      "approvalRequired": true,
      "riskLevel": "dangerous",
      "retryPolicy": { "maxRetries": 1, "retryDelayMs": 10000 },
      "timeout": 600000,
      "finalOutputContribution": "Release execution"
    },
    {
      "id": "generate-release-report",
      "title": "Generate release report",
      "description": "Document release summary, deployed version, validation results, and post-release notes",
      "taskType": "documentation",
      "actionType": "generate",
      "executor": "shell",
      "dependsOn": ["execute-deployment"],
      "inputContext": "All release outputs",
      "targetFiles": ["reports/release-report.md"],
      "targetArtifacts": ["release-report"],
      "expectedResult": "Release report with deployment summary",
      "expectedOutputType": "report",
      "acceptanceCriteria": ["Release report exists with deployment summary"],
      "evidence": ["report file exists"],
      "validationMethod": "file_exists",
      "riskLevel": "safe",
      "finalOutputContribution": "Final release deliverable"
    }
  ]
}
