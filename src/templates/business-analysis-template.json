{
  "id": "business-analysis",
  "name": "Business Analysis",
  "description": "Structured workflow for business analysis including requirement extraction, gap analysis, stakeholder analysis, and recommendations",
  "workflowType": "business-analysis",
  "category": "analysis",
  "version": "1.0",
  "tags": ["business", "analysis", "requirements"],
  "defaultMode": "auto",
  "estimatedDuration": "1h-4h",
  "typicalSteps": 7,
  "metadata": {
    "requiresScan": true,
    "requiresApproval": false,
    "requiresCodegraph": false,
    "outputTypes": ["analysis", "report", "recommendation", "checklist"]
  },
  "steps": [
    {
      "id": "understand-context",
      "title": "Understand business context and goals",
      "description": "Analyze the business context, objectives, constraints, and success criteria",
      "taskType": "analysis",
      "actionType": "analyze",
      "executor": "shell",
      "targetArtifacts": ["business-context"],
      "expectedResult": "Business context and goals documented",
      "expectedOutputType": "analysis",
      "acceptanceCriteria": ["Business context and goals are documented"],
      "evidence": ["context document exists"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Foundation for all analysis work"
    },
    {
      "id": "extract-requirements",
      "title": "Extract and analyze requirements",
      "description": "Identify, categorize, and document functional and non-functional requirements from available sources",
      "taskType": "analysis",
      "actionType": "analyze",
      "executor": "shell",
      "dependsOn": ["understand-context"],
      "inputContext": "Business context, user prompt",
      "targetArtifacts": ["requirements-document"],
      "expectedResult": "Requirements extracted and categorized",
      "expectedOutputType": "analysis",
      "acceptanceCriteria": ["Requirements are documented with categorization"],
      "evidence": ["requirements document exists"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Defines what needs to be built or done"
    },
    {
      "id": "perform-gap-analysis",
      "title": "Perform gap analysis",
      "description": "Analyze current state vs desired state and identify gaps, risks, and missing capabilities",
      "taskType": "analysis",
      "actionType": "analyze",
      "executor": "shell",
      "dependsOn": ["extract-requirements"],
      "inputContext": "Requirements, business context",
      "targetArtifacts": ["gap-analysis"],
      "expectedResult": "Gaps and risks identified",
      "expectedOutputType": "analysis",
      "acceptanceCriteria": ["Gaps between current and desired state are documented"],
      "evidence": ["gap analysis exists"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Identifies what is missing or at risk"
    },
    {
      "id": "stakeholder-analysis",
      "title": "Stakeholder and risk analysis",
      "description": "Identify stakeholders, their interests, influence, and analyze project risks",
      "taskType": "analysis",
      "actionType": "analyze",
      "executor": "shell",
      "dependsOn": ["perform-gap-analysis"],
      "inputContext": "Requirements, context, gaps",
      "targetArtifacts": ["stakeholder-analysis"],
      "expectedResult": "Stakeholders and risks documented",
      "expectedOutputType": "analysis",
      "acceptanceCriteria": ["Stakeholders and risks are identified"],
      "evidence": ["analysis document exists"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Ensures stakeholder needs are considered"
    },
    {
      "id": "define-acceptance-criteria",
      "title": "Define acceptance criteria",
      "description": "Develop clear acceptance criteria for the proposed solution or change",
      "taskType": "analysis",
      "actionType": "generate",
      "executor": "shell",
      "dependsOn": ["stakeholder-analysis"],
      "inputContext": "Requirements, stakeholder analysis",
      "targetArtifacts": ["acceptance-criteria"],
      "expectedResult": "Acceptance criteria defined",
      "expectedOutputType": "checklist",
      "acceptanceCriteria": ["Acceptance criteria are documented for all requirements"],
      "evidence": ["criteria document exists"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Success criteria for the project"
    },
    {
      "id": "generate-recommendations",
      "title": "Generate recommendations",
      "description": "Develop actionable recommendations based on the analysis",
      "taskType": "analysis",
      "actionType": "generate",
      "executor": "shell",
      "dependsOn": ["define-acceptance-criteria"],
      "inputContext": "All analysis outputs",
      "targetArtifacts": ["recommendations"],
      "expectedResult": "Recommendations documented with rationale",
      "expectedOutputType": "recommendation",
      "acceptanceCriteria": ["Recommendations are documented with supporting rationale"],
      "evidence": ["recommendations exist"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Actionable business guidance"
    },
    {
      "id": "generate-report",
      "title": "Generate business analysis report",
      "description": "Produce comprehensive BA report with requirements, gaps, risks, criteria, and recommendations",
      "taskType": "documentation",
      "actionType": "generate",
      "executor": "shell",
      "dependsOn": ["generate-recommendations"],
      "inputContext": "All BA outputs",
      "targetFiles": ["reports/ba-report.md"],
      "targetArtifacts": ["ba-report"],
      "expectedResult": "BA report with all analysis findings",
      "expectedOutputType": "report",
      "acceptanceCriteria": ["BA report exists with all analysis sections"],
      "evidence": ["report file exists"],
      "validationMethod": "file_exists",
      "riskLevel": "safe",
      "finalOutputContribution": "Final BA deliverable"
    }
  ]
}
