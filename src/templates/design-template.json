{
  "id": "design",
  "name": "Design Workflow",
  "description": "Structured workflow for UI/UX design including requirement analysis, component design, implementation, and quality review",
  "workflowType": "design",
  "category": "creative",
  "version": "1.0",
  "tags": ["design", "ui", "ux", "visual"],
  "defaultMode": "auto",
  "estimatedDuration": "30min-3h",
  "typicalSteps": 7,
  "metadata": {
    "requiresScan": true,
    "requiresApproval": false,
    "requiresCodegraph": false,
    "outputTypes": ["design_artifact", "ui_change", "file", "screenshot"]
  },
  "steps": [
    {
      "id": "understand-design-requirements",
      "title": "Understand design requirements",
      "description": "Analyze design requirements, user needs, visual style guidelines, and accessibility standards",
      "taskType": "design",
      "actionType": "analyze",
      "executor": "shell",
      "targetArtifacts": ["design-requirements"],
      "expectedResult": "Design requirements documented",
      "expectedOutputType": "analysis",
      "acceptanceCriteria": ["Design requirements and style guidelines are documented"],
      "evidence": ["requirements file exists"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Defines design objectives"
    },
    {
      "id": "review-existing-designs",
      "title": "Review existing design system",
      "description": "Examine existing UI components, design patterns, and design system in the project",
      "taskType": "design",
      "actionType": "read",
      "executor": "shell",
      "dependsOn": ["understand-design-requirements"],
      "targetArtifacts": ["design-review"],
      "expectedResult": "Existing design patterns reviewed",
      "expectedOutputType": "analysis",
      "acceptanceCriteria": ["Existing design patterns and components are reviewed"],
      "evidence": ["review file exists"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Builds on existing design language"
    },
    {
      "id": "plan-design-solution",
      "title": "Plan design solution",
      "description": "Design the visual approach, component structure, layout, and interaction patterns",
      "taskType": "design",
      "actionType": "create",
      "executor": "shell",
      "dependsOn": ["review-existing-designs"],
      "inputContext": "Design requirements, existing patterns",
      "targetArtifacts": ["design-plan"],
      "expectedResult": "Design solution planned with component specifications",
      "expectedOutputType": "design_artifact",
      "acceptanceCriteria": ["Design plan has component specs and layout"],
      "evidence": ["design plan exists"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Blueprint for implementation"
    },
    {
      "id": "create-design-assets",
      "title": "Create design assets",
      "description": "Create design artifacts, mockups, wireframes, or component prototypes",
      "taskType": "design",
      "actionType": "create",
      "executor": "shell",
      "dependsOn": ["plan-design-solution"],
      "inputContext": "Design plan",
      "targetFiles": ["src/"],
      "targetArtifacts": ["design-assets"],
      "expectedResult": "Design assets created",
      "expectedOutputType": "design_artifact",
      "acceptanceCriteria": ["Design assets are created per plan"],
      "evidence": ["design assets exist"],
      "validationMethod": "file_exists",
      "riskLevel": "safe",
      "retryPolicy": { "maxRetries": 2, "retryDelayMs": 2000 },
      "timeout": 300000,
      "finalOutputContribution": "Core design deliverable"
    },
    {
      "id": "implement-ui",
      "title": "Implement UI components",
      "description": "Implement the design as UI components following design specifications and accessibility standards",
      "taskType": "design",
      "actionType": "create",
      "executor": "shell",
      "dependsOn": ["create-design-assets"],
      "inputContext": "Design assets, design plan",
      "targetFiles": ["src/"],
      "targetArtifacts": ["ui-implementation"],
      "expectedResult": "UI components implemented",
      "expectedOutputType": "ui_change",
      "acceptanceCriteria": ["UI components are implemented per design"],
      "evidence": ["ui files changed"],
      "validationMethod": "hybrid",
      "riskLevel": "safe",
      "retryPolicy": { "maxRetries": 2, "retryDelayMs": 1000 },
      "finalOutputContribution": "Implementation deliverable"
    },
    {
      "id": "verify-design-quality",
      "title": "Verify design quality",
      "description": "Check UI for consistency, accessibility, responsiveness, and adherence to design guidelines",
      "taskType": "validation",
      "actionType": "validate",
      "executor": "shell",
      "dependsOn": ["implement-ui"],
      "inputContext": "UI implementation, design requirements",
      "targetArtifacts": ["design-validation"],
      "expectedResult": "Design quality validated",
      "expectedOutputType": "report",
      "acceptanceCriteria": ["Design meets quality and accessibility standards"],
      "evidence": ["validation completed"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Confirms design quality"
    },
    {
      "id": "generate-report",
      "title": "Generate design report",
      "description": "Document design decisions, changes, and outcomes",
      "taskType": "documentation",
      "actionType": "generate",
      "executor": "shell",
      "dependsOn": ["verify-design-quality"],
      "inputContext": "All design outputs",
      "targetFiles": ["reports/design-report.md"],
      "targetArtifacts": ["design-report"],
      "expectedResult": "Design report with decision summary",
      "expectedOutputType": "report",
      "acceptanceCriteria": ["Design report exists with decisions documented"],
      "evidence": ["report file exists"],
      "validationMethod": "file_exists",
      "riskLevel": "safe",
      "finalOutputContribution": "Final design deliverable"
    }
  ]
}
