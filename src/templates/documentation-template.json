{
  "id": "documentation",
  "name": "Documentation",
  "description": "Structured workflow for creating, updating, and reviewing project documentation",
  "workflowType": "documentation",
  "category": "content",
  "version": "1.0",
  "tags": ["docs", "documentation", "writing"],
  "defaultMode": "auto",
  "estimatedDuration": "20min-2h",
  "typicalSteps": 6,
  "metadata": {
    "requiresScan": true,
    "requiresApproval": false,
    "requiresCodegraph": false,
    "outputTypes": ["document", "file", "report"]
  },
  "steps": [
    {
      "id": "read-project-rules",
      "title": "Read project rules and documentation standards",
      "description": "Load and review project rules and documentation conventions",
      "taskType": "general",
      "actionType": "read",
      "executor": "shell",
      "targetArtifacts": ["rules-review"],
      "expectedResult": "Documentation standards reviewed",
      "acceptanceCriteria": ["Documentation standards and conventions are reviewed"],
      "evidence": ["rules reviewed"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Ensures docs follow project conventions"
    },
    {
      "id": "understand-documentation-needs",
      "title": "Understand documentation needs",
      "description": "Analyze what documentation is needed, target audience, and purpose",
      "taskType": "analysis",
      "actionType": "analyze",
      "executor": "shell",
      "dependsOn": ["read-project-rules"],
      "targetArtifacts": ["doc-requirements"],
      "expectedResult": "Documentation scope and audience defined",
      "expectedOutputType": "analysis",
      "acceptanceCriteria": ["Documentation scope and audience are defined"],
      "evidence": ["requirements file exists"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Defines what documentation to produce"
    },
    {
      "id": "review-existing-docs",
      "title": "Review existing documentation",
      "description": "Examine existing documentation to understand current state, coverage, and gaps",
      "taskType": "general",
      "actionType": "read",
      "executor": "shell",
      "dependsOn": ["understand-documentation-needs"],
      "targetArtifacts": ["existing-docs-review"],
      "expectedResult": "Existing documentation gaps identified",
      "expectedOutputType": "analysis",
      "acceptanceCriteria": ["Documentation gaps are identified"],
      "evidence": ["review file exists"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Prevents duplicate or unnecessary documentation"
    },
    {
      "id": "create-outline",
      "title": "Create documentation outline",
      "description": "Structure the documentation with clear sections, flow, and organization",
      "taskType": "documentation",
      "actionType": "create",
      "executor": "shell",
      "dependsOn": ["review-existing-docs"],
      "inputContext": "Doc requirements, existing docs review",
      "targetArtifacts": ["doc-outline"],
      "expectedResult": "Documentation outline with structured sections",
      "expectedOutputType": "document",
      "acceptanceCriteria": ["Outline exists with structured sections"],
      "evidence": ["outline file exists"],
      "validationMethod": "file_exists",
      "riskLevel": "safe",
      "finalOutputContribution": "Blueprint for documentation writing"
    },
    {
      "id": "write-documentation",
      "title": "Write documentation",
      "description": "Write the documentation content following project standards and the outline",
      "taskType": "documentation",
      "actionType": "create",
      "executor": "shell",
      "dependsOn": ["create-outline"],
      "inputContext": "Documentation outline, standards",
      "targetFiles": ["docs/"],
      "targetArtifacts": ["documentation-files"],
      "expectedResult": "Documentation files with complete content",
      "expectedOutputType": "document",
      "acceptanceCriteria": ["Documentation files exist with complete content"],
      "evidence": ["doc files exist"],
      "validationMethod": "file_exists",
      "riskLevel": "safe",
      "retryPolicy": { "maxRetries": 2, "retryDelayMs": 1000 },
      "finalOutputContribution": "Core documentation deliverable"
    },
    {
      "id": "review-and-finalize",
      "title": "Review and finalize documentation",
      "description": "Review documentation for clarity, accuracy, completeness, and consistency",
      "taskType": "review",
      "actionType": "review",
      "executor": "shell",
      "dependsOn": ["write-documentation"],
      "inputContext": "Draft documentation, standards",
      "targetFiles": ["docs/"],
      "targetArtifacts": ["review-notes"],
      "expectedResult": "Documentation reviewed and finalized",
      "expectedOutputType": "document",
      "acceptanceCriteria": ["Documentation is reviewed and finalized"],
      "evidence": ["review completed", "docs finalized"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Ensures documentation quality"
    }
  ]
}
