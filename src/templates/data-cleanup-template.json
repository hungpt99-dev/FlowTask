{
  "id": "data-cleanup",
  "name": "Data Cleanup",
  "description": "Structured workflow for data cleaning, transformation, deduplication, and quality improvement",
  "workflowType": "data-cleanup",
  "category": "data",
  "version": "1.0",
  "tags": ["data", "cleanup", "transformation", "quality"],
  "defaultMode": "auto",
  "estimatedDuration": "30min-2h",
  "typicalSteps": 6,
  "metadata": {
    "requiresScan": true,
    "requiresApproval": false,
    "requiresCodegraph": false,
    "outputTypes": ["data_file", "data_change", "report", "analysis"]
  },
  "steps": [
    {
      "id": "understand-data",
      "title": "Understand data and cleanup requirements",
      "description": "Analyze the data sources, understand quality issues, and define cleanup goals",
      "taskType": "data",
      "actionType": "analyze",
      "executor": "shell",
      "targetArtifacts": ["cleanup-requirements"],
      "expectedResult": "Data cleanup requirements documented",
      "expectedOutputType": "analysis",
      "acceptanceCriteria": ["Cleanup goals and quality criteria are defined"],
      "evidence": ["requirements file exists"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Defines cleanup objectives"
    },
    {
      "id": "audit-data-quality",
      "title": "Audit data quality",
      "description": "Assess current data quality, identify issues like duplicates, missing values, inconsistencies, and outliers",
      "taskType": "data",
      "actionType": "analyze",
      "executor": "shell",
      "dependsOn": ["understand-data"],
      "inputContext": "Cleanup requirements",
      "targetFiles": ["data/"],
      "targetArtifacts": ["quality-audit"],
      "expectedResult": "Data quality audit with issues identified",
      "expectedOutputType": "analysis",
      "acceptanceCriteria": ["Data quality issues are identified and documented"],
      "evidence": ["audit file exists"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Identifies what needs fixing"
    },
    {
      "id": "design-cleanup-plan",
      "title": "Design cleanup approach",
      "description": "Design the data cleaning and transformation approach for each identified issue",
      "taskType": "data",
      "actionType": "analyze",
      "executor": "shell",
      "dependsOn": ["audit-data-quality"],
      "inputContext": "Quality audit",
      "targetArtifacts": ["cleanup-plan"],
      "expectedResult": "Cleanup approach designed for each issue",
      "expectedOutputType": "analysis",
      "acceptanceCriteria": ["Cleanup plan addresses all identified issues"],
      "evidence": ["plan file exists"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Blueprint for cleanup execution"
    },
    {
      "id": "execute-cleanup",
      "title": "Execute data cleanup",
      "description": "Apply data cleaning transformations: deduplicate, fix formats, handle missing values, and standardize",
      "taskType": "data",
      "actionType": "transform",
      "executor": "shell",
      "dependsOn": ["design-cleanup-plan"],
      "inputContext": "Cleanup plan, source data",
      "targetFiles": ["data/"],
      "targetArtifacts": ["cleaned-data"],
      "expectedResult": "Data cleaned according to the plan",
      "expectedOutputType": "data_change",
      "acceptanceCriteria": ["Data is cleaned according to the plan"],
      "evidence": ["cleaning completed"],
      "validationMethod": "hybrid",
      "approvalRequired": true,
      "riskLevel": "risky",
      "retryPolicy": { "maxRetries": 2, "retryDelayMs": 1000 },
      "timeout": 300000,
      "finalOutputContribution": "Core cleanup deliverable"
    },
    {
      "id": "validate-cleanup",
      "title": "Validate cleanup results",
      "description": "Verify that all quality issues are resolved and cleanup criteria are met",
      "taskType": "validation",
      "actionType": "validate",
      "executor": "shell",
      "dependsOn": ["execute-cleanup"],
      "inputContext": "Cleanup plan, cleaned data",
      "targetArtifacts": ["validation-results"],
      "expectedResult": "Cleanup validated against quality criteria",
      "expectedOutputType": "report",
      "acceptanceCriteria": ["All quality criteria are met"],
      "evidence": ["validation passes"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Confirms cleanup quality"
    },
    {
      "id": "generate-report",
      "title": "Generate cleanup report",
      "description": "Document what was cleaned, transformations applied, and final data quality metrics",
      "taskType": "documentation",
      "actionType": "generate",
      "executor": "shell",
      "dependsOn": ["validate-cleanup"],
      "inputContext": "Cleanup plan, validation results",
      "targetFiles": ["reports/cleanup-report.md"],
      "targetArtifacts": ["cleanup-report"],
      "expectedResult": "Cleanup report with transformation details",
      "expectedOutputType": "report",
      "acceptanceCriteria": ["Cleanup report exists with details"],
      "evidence": ["report file exists"],
      "validationMethod": "file_exists",
      "riskLevel": "safe",
      "finalOutputContribution": "Final cleanup deliverable"
    }
  ]
}
