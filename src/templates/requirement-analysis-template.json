{
  "id": "requirement-analysis",
  "name": "Requirement Analysis",
  "description": "Structured workflow for analyzing, documenting, and validating requirements",
  "workflowType": "requirement-analysis",
  "category": "analysis",
  "version": "1.0",
  "tags": ["requirements", "analysis", "specification"],
  "defaultMode": "auto",
  "estimatedDuration": "30min-3h",
  "typicalSteps": 7,
  "metadata": {
    "requiresScan": true,
    "requiresApproval": true,
    "requiresCodegraph": false,
    "outputTypes": ["analysis", "report", "checklist", "recommendation"]
  },
  "steps": [
    {
      "id": "understand-project-context",
      "title": "Understand project context",
      "description": "Review project background, existing documentation, and relevant context",
      "taskType": "analysis",
      "actionType": "read",
      "executor": "shell",
      "targetArtifacts": ["context-summary"],
      "expectedResult": "Project context documented",
      "expectedOutputType": "analysis",
      "acceptanceCriteria": ["Project context is reviewed and documented"],
      "evidence": ["context summary exists"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Foundation for requirement analysis"
    },
    {
      "id": "gather-inputs",
      "title": "Gather requirement inputs",
      "description": "Collect all available requirement sources: prompts, documents, stakeholder inputs, existing specs",
      "taskType": "analysis",
      "actionType": "read",
      "executor": "shell",
      "dependsOn": ["understand-project-context"],
      "inputContext": "Project context",
      "targetArtifacts": ["requirement-sources"],
      "expectedResult": "All requirement sources collected",
      "expectedOutputType": "analysis",
      "acceptanceCriteria": ["All available requirement sources are collected"],
      "evidence": ["sources documented"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Raw requirement material"
    },
    {
      "id": "extract-and-categorize",
      "title": "Extract and categorize requirements",
      "description": "Extract individual requirements, categorize by type (functional, non-functional, constraints), and assign priorities",
      "taskType": "analysis",
      "actionType": "analyze",
      "executor": "shell",
      "dependsOn": ["gather-inputs"],
      "inputContext": "Requirement sources",
      "targetArtifacts": ["categorized-requirements"],
      "expectedResult": "Requirements extracted and categorized",
      "expectedOutputType": "analysis",
      "acceptanceCriteria": ["Requirements are extracted with categories and priorities"],
      "evidence": ["requirements documented"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "retryPolicy": { "maxRetries": 2, "retryDelayMs": 1000 },
      "finalOutputContribution": "Structured requirement set"
    },
    {
      "id": "analyze-feasibility",
      "title": "Analyze feasibility and constraints",
      "description": "Assess technical feasibility, resource constraints, timeline impacts, and risks for each requirement",
      "taskType": "analysis",
      "actionType": "analyze",
      "executor": "shell",
      "dependsOn": ["extract-and-categorize"],
      "inputContext": "Categorized requirements",
      "targetArtifacts": ["feasibility-analysis"],
      "expectedResult": "Feasibility analyzed for all requirements",
      "expectedOutputType": "analysis",
      "acceptanceCriteria": ["Feasibility and constraints are documented"],
      "evidence": ["feasibility analysis exists"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Identifies achievable scope"
    },
    {
      "id": "define-acceptance-criteria",
      "title": "Define acceptance criteria",
      "description": "Develop clear, testable acceptance criteria for each requirement",
      "taskType": "analysis",
      "actionType": "generate",
      "executor": "shell",
      "dependsOn": ["analyze-feasibility"],
      "inputContext": "Requirements, feasibility analysis",
      "targetArtifacts": ["acceptance-criteria"],
      "expectedResult": "Acceptance criteria defined for all requirements",
      "expectedOutputType": "checklist",
      "acceptanceCriteria": ["Each requirement has testable acceptance criteria"],
      "evidence": ["criteria documented"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Testable success criteria"
    },
    {
      "id": "identify-gaps",
      "title": "Identify gaps and ambiguities",
      "description": "Identify missing requirements, ambiguities, conflicts, and areas needing clarification",
      "taskType": "analysis",
      "actionType": "analyze",
      "executor": "shell",
      "dependsOn": ["define-acceptance-criteria"],
      "inputContext": "Requirements, criteria",
      "targetArtifacts": ["gap-analysis"],
      "expectedResult": "Gaps and ambiguities identified",
      "expectedOutputType": "analysis",
      "acceptanceCriteria": ["Gaps and ambiguities are documented"],
      "evidence": ["gap analysis exists"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Completion criteria"
    },
    {
      "id": "generate-specification",
      "title": "Generate requirements specification",
      "description": "Produce comprehensive requirements specification document with all analysis findings",
      "taskType": "documentation",
      "actionType": "generate",
      "executor": "shell",
      "dependsOn": ["identify-gaps"],
      "inputContext": "All analysis outputs",
      "targetFiles": ["docs/requirements-spec.md"],
      "targetArtifacts": ["requirements-spec"],
      "expectedResult": "Requirements specification document",
      "expectedOutputType": "report",
      "acceptanceCriteria": ["Requirements spec exists with all sections"],
      "evidence": ["spec file exists"],
      "validationMethod": "file_exists",
      "riskLevel": "safe",
      "finalOutputContribution": "Final requirements deliverable"
    }
  ]
}
