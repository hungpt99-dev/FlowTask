{
  "id": "data-analysis",
  "name": "Data Analysis",
  "description": "Structured workflow for data processing, analysis, visualization, and reporting",
  "workflowType": "data-analysis",
  "category": "data",
  "version": "1.0",
  "tags": ["data", "analysis", "visualization"],
  "defaultMode": "auto",
  "estimatedDuration": "30min-3h",
  "typicalSteps": 7,
  "metadata": {
    "requiresScan": true,
    "requiresApproval": false,
    "requiresCodegraph": false,
    "outputTypes": ["data_file", "analysis", "report", "file"]
  },
  "steps": [
    {
      "id": "understand-data-requirements",
      "title": "Understand data requirements",
      "description": "Analyze what data is needed, what questions to answer, and define analysis approach",
      "taskType": "data",
      "actionType": "analyze",
      "executor": "shell",
      "targetArtifacts": ["data-requirements"],
      "expectedResult": "Data requirements and analysis questions defined",
      "expectedOutputType": "analysis",
      "acceptanceCriteria": ["Data requirements and analysis questions are defined"],
      "evidence": ["requirements file exists"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Focuses the data analysis effort"
    },
    {
      "id": "gather-data",
      "title": "Gather or load data",
      "description": "Collect, load, or generate required data from available sources",
      "taskType": "data",
      "actionType": "read",
      "executor": "shell",
      "dependsOn": ["understand-data-requirements"],
      "inputContext": "Data requirements",
      "targetFiles": ["data/"],
      "targetArtifacts": ["gathered-data"],
      "expectedResult": "Data gathered and validated",
      "expectedOutputType": "data_file",
      "acceptanceCriteria": ["Data files exist and are valid"],
      "evidence": ["data files exist"],
      "validationMethod": "file_exists",
      "riskLevel": "safe",
      "finalOutputContribution": "Raw material for analysis"
    },
    {
      "id": "explore-data",
      "title": "Explore and clean data",
      "description": "Explore data structure, detect schema, handle missing values, and prepare data for analysis",
      "taskType": "data",
      "actionType": "transform",
      "executor": "shell",
      "dependsOn": ["gather-data"],
      "inputContext": "Gathered data",
      "targetFiles": ["data/"],
      "targetArtifacts": ["cleaned-data"],
      "expectedResult": "Data cleaned and ready for analysis",
      "expectedOutputType": "data_file",
      "acceptanceCriteria": ["Data is cleaned with schema documented"],
      "evidence": ["cleaned data exists"],
      "validationMethod": "hybrid",
      "riskLevel": "safe",
      "finalOutputContribution": "Clean data for analysis"
    },
    {
      "id": "analyze-data",
      "title": "Analyze and process data",
      "description": "Run analysis, compute statistics, identify patterns, and generate insights",
      "taskType": "data",
      "actionType": "analyze",
      "executor": "shell",
      "dependsOn": ["explore-data"],
      "inputContext": "Cleaned data",
      "targetArtifacts": ["analysis-results"],
      "expectedResult": "Analysis results computed",
      "expectedOutputType": "analysis",
      "acceptanceCriteria": ["Analysis results are computed with insights documented"],
      "evidence": ["results file exists"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "retryPolicy": { "maxRetries": 2, "retryDelayMs": 1000 },
      "finalOutputContribution": "Core analytical insights"
    },
    {
      "id": "create-visualizations",
      "title": "Create visualizations",
      "description": "Create charts, graphs, or visual representations of the findings",
      "taskType": "data",
      "actionType": "generate",
      "executor": "shell",
      "dependsOn": ["analyze-data"],
      "inputContext": "Analysis results",
      "targetFiles": ["visualizations/"],
      "targetArtifacts": ["visualizations"],
      "expectedResult": "Visualizations created from analysis results",
      "expectedOutputType": "file",
      "acceptanceCriteria": ["Visualization files exist with charts or graphs"],
      "evidence": ["visualization files exist"],
      "validationMethod": "file_exists",
      "riskLevel": "safe",
      "finalOutputContribution": "Visual communication of findings"
    },
    {
      "id": "validate-results",
      "title": "Validate analysis results",
      "description": "Verify analysis accuracy, check data quality, and validate conclusions",
      "taskType": "validation",
      "actionType": "validate",
      "executor": "shell",
      "dependsOn": ["create-visualizations"],
      "inputContext": "Analysis results, data",
      "targetArtifacts": ["validation-results"],
      "expectedResult": "Analysis results validated for correctness",
      "expectedOutputType": "analysis",
      "acceptanceCriteria": ["Analysis is validated for correctness"],
      "evidence": ["validation completed"],
      "validationMethod": "ai_review",
      "riskLevel": "safe",
      "finalOutputContribution": "Confirms analysis quality"
    },
    {
      "id": "generate-report",
      "title": "Generate analysis report",
      "description": "Document methodology, findings, insights, and conclusions in a comprehensive report",
      "taskType": "documentation",
      "actionType": "generate",
      "executor": "shell",
      "dependsOn": ["validate-results"],
      "inputContext": "All analysis outputs",
      "targetFiles": ["reports/analysis-report.md"],
      "targetArtifacts": ["analysis-report"],
      "expectedResult": "Analysis report with methodology and findings",
      "expectedOutputType": "report",
      "acceptanceCriteria": ["Analysis report exists with methodology and findings"],
      "evidence": ["report file exists"],
      "validationMethod": "file_exists",
      "riskLevel": "safe",
      "finalOutputContribution": "Final analysis deliverable"
    }
  ]
}
